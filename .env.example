# LM Studio (servidor local com modelo de embedding carregado)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=bge-m3
EMBEDDING_DIM=1024

# Supabase — use a SERVICE ROLE KEY (não a anon), pois vamos fazer insert em massa
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# Caminho do JSON (relativo à raiz do projeto) e nome da tabela
INPUT_JSON=data/chunks_hibridos_catalogo_completo.json
TABLE_NAME=documents

# Tamanho do lote de embeddings enviados ao LM Studio por requisição
BATCH_SIZE=32
